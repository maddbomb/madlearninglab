---
import Base from '../layouts/Base.astro';
---
<Base title="Contact — Mad Learning Lab" description="Get in touch with Mad Learning Lab about research, evaluation, or capacity-building work for your organization.">
  <section class="page">
    <p class="page-eyebrow">Contact</p>
    <h2 class="page-title">Let's talk.</h2>
    <p>
      Tell me a little about your organization and what you're working on. I respond to every
      inquiry within a couple of business days.
    </p>

    <form
      class="contact-form"
      action="https://formsubmit.co/madlearninglab@gmail.com"
      method="POST"
    >
      <input type="hidden" name="_subject" value="New inquiry from madlearninglab.com" />
      <input type="hidden" name="_template" value="box" />
      <input type="hidden" name="_next" value="https://madlearninglab.com/thanks" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="text" name="_honey" class="honeypot" tabindex="-1" autocomplete="off" />

      <div class="field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required autocomplete="name" />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>

      <div class="field">
        <label for="organization">Organization <span class="optional">(optional)</span></label>
        <input type="text" id="organization" name="organization" autocomplete="organization" />
      </div>

      <fieldset class="budget-field">
        <legend>What is your budget range?</legend>
        <div class="radio-list">
          <label class="radio-option">
            <input type="radio" name="budget" value="$1,000–5,999" />
            <span>$1,000–5,999</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="budget" value="$6,000–18,999" />
            <span>$6,000–18,999</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="budget" value="$19,000–29,999" />
            <span>$19,000–29,999</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="budget" value="$30,000–79,999" />
            <span>$30,000–79,999</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="budget" value="$80,000+" />
            <span>$80,000+</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="budget" value="I don't have a set budget" />
            <span>I don't have a set budget</span>
          </label>
        </div>
      </fieldset>

      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="6" required></textarea>
      </div>

      <button type="submit" class="cta">
        Send message
        <span class="cta-arrow" aria-hidden="true">→</span>
      </button>
    </form>

    <p class="contact-fallback">
      Prefer email? Reach me directly at
      <a href="mailto:madlearninglab@gmail.com">madlearninglab@gmail.com</a>.
    </p>
  </section>
</Base>
