---
import Base from '../layouts/Base.astro';
---
<Base title="Thanks — Mad Learning Lab" description="Thanks for reaching out to Mad Learning Lab.">
  <section class="page">
    <p class="page-eyebrow">Thanks</p>
    <h2 class="page-title">Message received.</h2>
    <p>
      Thanks for reaching out. I've got your note and will get back to you within a couple of
      business days.
    </p>
    <p class="thanks-back">
      <a href="/" class="cta">
        Back to home
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
    </p>
  </section>
</Base>
